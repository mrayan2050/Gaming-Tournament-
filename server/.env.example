# ── Server ───────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ── Supabase PostgreSQL ─────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database
# DATABASE_URL = "Connection pooling" string (port 6543, for app queries)
# DIRECT_URL   = "Connection string" direct (port 5432, for migrations)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ── JWT (our own backend session token, issued after Firebase verifies user) ──
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=30d

# ── Firebase Admin SDK ───────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Service Accounts
#   → Generate New Private Key (downloads a JSON file)
# Copy the three fields below from that JSON.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# IMPORTANT: keep the \n literal characters, wrap in quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Razorpay (real wallet deposits) ───────────────────────────
# Get free TEST-mode keys from: Razorpay Dashboard → Settings → API Keys
# (No business verification needed to test — live keys need KYC first)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_key_secret
